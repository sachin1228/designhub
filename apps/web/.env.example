# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# Never commit .env or .env.local — they are gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Session signing secret (generate with: openssl rand -base64 32)
SESSION_SECRET=your-random-secret

# Admin credentials
ADMIN_EMAIL=admin@example.com

# ⚠️  IMPORTANT — single quotes are required around the bcrypt hash.
#
# Dotenv expands bare $ signs as variable references, which mangles bcrypt
# hashes (they start with $2a$, $2b$, or $2y$).  Single quotes tell dotenv
# to treat the value literally and preserve every $ character.
#
# Correct:
#   ADMIN_PASSWORD='$2a$12$...'
#
# Wrong ($ signs will be expanded to empty strings locally):
#   ADMIN_PASSWORD=$2a$12$...
#   ADMIN_PASSWORD="$2a$12$..."
#
# Generate a hash: node -e "require('bcryptjs').hash('yourpassword',12).then(console.log)"
ADMIN_PASSWORD='$2a$12$replace-this-with-your-actual-hash'

# Email (Resend)
RESEND_API_KEY=re_your_key
EMAIL_FROM=noreply@yourdomain.com
