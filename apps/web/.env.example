# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# Never commit .env or .env.local — they are gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Session signing secret (generate with: openssl rand -base64 32)
SESSION_SECRET=your-random-secret

# Admin credentials — plain text password
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-strong-plain-text-password

# Email (Resend)
RESEND_API_KEY=re_your_key
EMAIL_FROM=noreply@yourdomain.com

# Upstash Redis — used by the rate limiter (sliding window, multi-instance safe)
# Create a database at https://console.upstash.com, then copy the REST URL and token
# from the database detail page → "REST API" section.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Cloudflare R2 — image storage (replaces Supabase Storage)
# 1. Go to Cloudflare dashboard → R2 → Create bucket
# 2. Go to R2 → Manage R2 API Tokens → Create token (Object Read & Write)
# 3. Enable public access on the bucket and copy the public URL
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Moderation
MODERATION_TEXT_MAX_LENGTH=2000
MODERATION_TEXT_BURST_LIMIT=5
MODERATION_TEXT_MINUTE_LIMIT=20
MODERATION_REJECT_KEYWORDS=
MODERATION_REVIEW_KEYWORDS=
MODERATION_PROFANITY_WORDS=
MODERATION_IMAGE_SERVICE_URL=http://localhost:8000
MODERATION_IMAGE_TIMEOUT_MS=8000
MODERATION_IMAGE_MAX_BYTES=20971520
