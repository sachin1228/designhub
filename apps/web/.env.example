# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# Never commit .env or .env.local — they are gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Session signing secret (generate with: openssl rand -base64 32)
SESSION_SECRET=your-random-secret

# Admin credentials
ADMIN_EMAIL=admin@example.com

# ── Admin password hash ────────────────────────────────────────────────────
#
# Next.js runs dotenv-expand after dotenv, which expands $VAR references even
# inside single-quoted strings.  Because bcrypt hashes start with $2a$, $2b$,
# or $2y$, storing them unencoded in a .env file corrupts the value locally
# (Vercel / Docker inject env vars without dotenv, so production is fine).
#
# SOLUTION — use ADMIN_PASSWORD_HASH (base64-encoded):
#   Base64 contains only [A-Za-z0-9+/=], so dotenv-expand leaves it untouched.
#
# Step 1 — generate a bcrypt hash (if you don't have one yet):
#   node -e "require('bcryptjs').hash('yourpassword', 12).then(console.log)"
#
# Step 2 — base64-encode it (copy the hash from step 1, paste below):
#   echo -n '$2a$12$YOUR_HASH_HERE' | base64
#
# Step 3 — paste the base64 output here (no quotes needed):
ADMIN_PASSWORD_HASH=replace-with-base64-encoded-bcrypt-hash

# ── Vercel / Docker / CI ──────────────────────────────────────────────────
# On platforms that inject env vars without dotenv (Vercel, Docker, GitHub
# Actions), you can keep using the raw hash in ADMIN_PASSWORD instead.
# The code tries ADMIN_PASSWORD_HASH first and falls back to ADMIN_PASSWORD.
#
# ADMIN_PASSWORD=$2a$12$...   ← works on Vercel; broken in local .env files

# Email (Resend)
RESEND_API_KEY=re_your_key
EMAIL_FROM=noreply@yourdomain.com
