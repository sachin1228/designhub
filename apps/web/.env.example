# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service-role key (server-only, never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Session ───────────────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -base64 32
SESSION_SECRET=replace-with-a-long-random-secret

# ── Admin ─────────────────────────────────────────────────────────────────────
# Credentials for the /admin dashboard
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=replace-with-secure-password

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Sign up at https://resend.com and create an API key
RESEND_API_KEY=re_your_resend_api_key
# Must be a verified sender address in your Resend account
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── App ───────────────────────────────────────────────────────────────────────
# Set this to your production URL — used in invitation and password-reset email links.
# Wrong value = broken links in emails.
NEXT_PUBLIC_APP_URL=https://your-production-domain.vercel.app

# ── Invitation ────────────────────────────────────────────────────────────────
# How many days an invitation link stays valid (default: 7)
INVITATION_EXPIRY_DAYS=7
